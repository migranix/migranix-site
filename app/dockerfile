# ============================================================
# Migranix Backend Dockerfile
# Target: Hetzner CX22 (2vCPU / 4GB) via Coolify
# Includes: ODBC Driver 18 for SQL Server
#           python-oracledb thin mode (no Oracle Client needed)
# ============================================================
FROM python:3.11-slim

WORKDIR /app

# ---- 1. System packages needed before pip ----
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc g++ \
        curl gnupg2 \
        unixodbc-dev \
    && rm -rf /var/lib/apt/lists/*

# ---- 2. Microsoft ODBC Driver 18 for SQL Server ----
# Required by pyodbc for SQL Server connections
RUN curl -sSL https://packages.microsoft.com/keys/microsoft.asc \
        | gpg --dearmor -o /usr/share/keyrings/microsoft.gpg \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/microsoft.gpg] \
        https://packages.microsoft.com/debian/12/prod bookworm main" \
        > /etc/apt/sources.list.d/mssql-release.list \
    && apt-get update \
    && ACCEPT_EULA=Y apt-get install -y --no-install-recommends msodbcsql18 \
    && rm -rf /var/lib/apt/lists/*

# ---- 3. Python environment ----
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
ENV PIP_ROOT_USER_ACTION=ignore

# ---- 4. Python dependencies ----
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ---- 5. Application code ----
COPY . .

EXPOSE 8000
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
